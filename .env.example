# Database Configuration
# For Neon, use the DATABASE_URL value and keep this file out of version control.
# Example: postgres://user:pass@host:5432/dbname?sslmode=require&channel_binding=require
DATABASE_URL=
DB_HOST=db
DB_USER=cmsp_user
DB_PASS=cmsp_password
DB_NAME=cmsp_db
DB_PORT=5432
DB_ROOT_PASS=root_password

# MeSomb credentials
MESOMB_APPLICATION_KEY=
MESOMB_ACCESS_KEY=
MESOMB_SECRET_KEY=

# Council payment info
COUNCIL_MOMO_NUMBER=+237 6XX XXX XXX (MTN Mobile Money)
COUNCIL_OM_NUMBER=+237 6XX XXX XXX (Orange Money)
COUNCIL_ACCOUNT_NAME=CMSP - Council for Medico Sanitary Professionals

# Application
PHP_MEMORY_LIMIT=256M
PHP_MAX_UPLOAD_SIZE=50M
